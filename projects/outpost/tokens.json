{
  "name": "outpost",
  "extends": "magnify",
  "version": "1.0.0",
  "updated": "2026-05-04",

  "colors": {
    "bg": "#0A0A0A",
    "surface": "#F5F5F0",
    "accent": "#FFD600",
    "neutrals": {
      "metadata": "#888780",
      "secondary": "#444748",
      "divider": "#2C2C2A"
    }
  },

  "surfaces": {
    "dk": { "bg": "#0A0A0A", "fg": "#F5F5F0" },
    "lt": { "bg": "#F5F5F0", "fg": "#0A0A0A" },
    "yl": { "bg": "#FFD600", "fg": "#0A0A0A" }
  },

  "typography": {
    "headline": {
      "family": "Inter",
      "weight": 800,
      "fallback": ["Helvetica Neue", "Arial", "sans-serif"],
      "letterSpacing": "-0.04em",
      "use": "hero, h1, h2, títulos masivos (64px+)"
    },
    "body": {
      "family": "Inter",
      "weight": 500,
      "fallback": ["Helvetica Neue", "Arial", "sans-serif"],
      "letterSpacing": "0",
      "use": "cuerpo, eyebrow, captions, metadata"
    },
    "editorial": {
      "family": "DM Serif Display",
      "weight": 400,
      "fallback": ["Georgia", "serif"],
      "letterSpacing": "0",
      "use": "citas, hero serif, manifiesto"
    },
    "label": {
      "family": "PP Neue Montreal",
      "weight": 500,
      "fallback": ["JetBrains Mono", "SF Mono", "monospace"],
      "letterSpacing": "0.05em",
      "textTransform": "uppercase",
      "use": "chips técnicos, footers de dossier",
      "inherited": "magnify"
    }
  },

  "spacing": {
    "unit": 4,
    "gutter": 24,
    "margin": 48,
    "strokeStandard": 1.5,
    "strokeFine": 0.75,
    "strokeWordmark": 2.4
  },

  "particles": {
    "technical": {
      "wrap": "brackets",
      "case": "uppercase",
      "examples": ["[FIELD_REPORT]", "[ANALYSIS]", "[INTERVIEW]", "[STANDARD]", "[SPECIAL]", "[SERIAL_NO: 88-02]"],
      "use": "eyebrow, chip, footer técnico, taxonomía",
      "specific": "outpost"
    },
    "highlight": {
      "wrap": "brackets",
      "case": "lowercase",
      "renderRules": {
        "onDark": "italic 800 accent",
        "onLight": "italic 800 underlineThick",
        "onAccent": "underline"
      },
      "use": "énfasis editorial dentro de cuerpo o titular, máx 1 por elemento",
      "inherited": "magnify"
    }
  },

  "series": [
    {
      "id": "STANDARD",
      "label": "[STANDARD]",
      "description": "Episodio editorial 10-12min, David solo presentando con slides + cámara PiP",
      "share": "~80%",
      "duration": "10-12 min",
      "layout": "header limpio, una columna"
    },
    {
      "id": "INTERVIEW",
      "label": "[INTERVIEW]",
      "description": "Conversación con un invitado",
      "share": "~10-15%",
      "duration": "25-40 min",
      "layout": "split screen, dos voces"
    },
    {
      "id": "SPECIAL",
      "label": "[SPECIAL]",
      "description": "Edición disparada por evento del sector",
      "share": "máx 3/año",
      "duration": "variable",
      "layout": "header amarillo, alta densidad de logs técnicos"
    }
  ],

  "logo": {
    "wordmark": {
      "positive": "logo/outpost-wordmark-positive.svg",
      "negative": "logo/outpost-wordmark-negative.svg",
      "positiveMono": "logo/outpost-wordmark-positive-mono.svg"
    },
    "icon": "logo/outpost-icon.svg",
    "favicon": "logo/outpost-favicon.svg",
    "geometry": {
      "rings": [
        { "cx": 80, "cy": 100, "r": 50 },
        { "cx": 78, "cy": 102, "r": 48 },
        { "cx": 81, "cy": 98, "r": 46 }
      ],
      "dot": { "cx": 106, "cy": 74, "r": 16, "fill": "accent" },
      "stroke": 2.4
    }
  },

  "fonts": {
    "css": "fonts/fonts.css",
    "files": [
      "fonts/Inter.woff2",
      "fonts/Inter-ext.woff2",
      "fonts/DMSerifDisplay.woff2",
      "fonts/DMSerifDisplay-ext.woff2"
    ]
  },

  "rules": {
    "crescendo": "una sola señal amarilla por slide, reservada al cierre / CTA / revelación",
    "highlightPerElement": 1,
    "minMargin": 48,
    "noEmDashes": true,
    "noEmojis": true,
    "noHashtags": true,
    "tuteo": "singular"
  },

  "frontmatterRequired": ["proyecto", "serie", "episodio"]
}
